    в”‚   в”њв”Ђв”Ђ user-teams/{route.ts, [id]/route.ts}
    в”‚   в””в”Ђв”Ђ users/{route.ts, [id]/route.ts}
    в”њв”Ђв”Ђ auth/               # Login, logout, me, refresh, etc.
    в”‚   в”њв”Ђв”Ђ login/route.ts
