    в”њв”Ђв”Ђ admin/              # Admin-only endpoints
    в”‚   в”њв”Ђв”Ђ backup/route.ts
    в”‚   в”њв”Ђв”Ђ logs/route.ts
    в”‚   в”њв”Ђв”Ђ stats/route.ts
